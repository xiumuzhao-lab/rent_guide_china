# 腾讯位置服务 API 配置
# 申请地址: https://lbs.qq.com/dev/console/application/mine
# Key 管理中开启 SN 校验后会分配 SK
TENCENT_MAP_KEY=your_key_here
TENCENT_MAP_SK=your_sk_here

# 超级鹰验证码识别 (用于自动解决爬虫验证码)
# 注册地址: https://www.chaojiying.com/
CHAOJIYING_USER=your_username
CHAOJIYING_PASS=your_password

# 服务器部署配置
# deploy-server.sh 使用以下变量一键部署后端服务
DEPLOY_HOST=your_server_ip
DEPLOY_USER=root
DEPLOY_PORT=22
# 认证方式二选一: 密码或 SSH 密钥
# DEPLOY_PASSWORD=your_password
# DEPLOY_KEY=~/.ssh/id_rsa
DEPLOY_PATH=/opt/rent-radar
